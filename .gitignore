# Environnement virtuel
.venv/
venv/
env/

# Cache Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Notebooks
.ipynb_checkpoints/

# Données brutes volumineuses (suivies hors Git via Zenodo + checksums)
data/raw/*
!data/raw/CHECKSUMS.txt
!data/raw/.gitkeep

# Données intermédiaires lourdes (sauf tables légères versionnées)
data/processed/*
!data/processed/.gitkeep
!data/processed/alias_to_name.csv
!data/processed/ref_sif_named.csv
!data/processed/hgnc_to_bnet.csv
!data/processed/hgnc_unmapped_nodes.csv
!data/processed/hgnc_mapping_summary.md
!data/processed/sanitize_collisions.csv

# Sorties de solveurs (résultats régénérables, sauf rapports Markdown)
results/**/*.json
results/**/*.csv
!results/**/.gitkeep
!results/**/structural_diff.csv
!results/**/attractor_catalog.csv
!results/phase3/*.csv
!results/phase4/*.csv
!results/phase5/*.csv
!results/phase7/*.csv

# Figures générées
figures/**/*.png
figures/**/*.svg
figures/**/*.pdf
!figures/**/.gitkeep

# Manuscrit compilé (régénérable via make pdf)
docs/manuscript.pdf

# Logs de conversion (versionnés explicitement)
# (pas d'exclusion globale *.log pour garder conversion.log)

# Fichiers volumineux (> 50 Mo) à éviter
*.bak
*.tmp

# Snakemake
.snakemake/

# Logs (auto-generated)
logs/*.log

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
